# Example image: pi coding agent + piguild (built from this checkout).
#
# From the piguild repo root:
#   docker compose -f compose.example.yaml up --build
#
# Or copy this file to `Dockerfile` and point compose at `dockerfile: Dockerfile`.
#
# Host layout (paths are relative to compose — create beside the repo or change volumes):
#   mkdir -p config workspace pi-config/agent
#   cp piguild.config.example.json config/piguild.config.json
#   touch config/.env   # optional env vars for the container process
# Populate pi-config/ with Pi credentials (~/.pi layout, e.g. agent/settings.json, agent/auth.json).
#
# For smaller/faster builds, add a .dockerignore that excludes node_modules, dist, and .git.

FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    python3 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Latest global install; align with piguild's peerDependency in package.json if builds fail.
RUN npm install -g @mariozechner/pi-coding-agent

WORKDIR /app

# Build context should be this repository root (the folder that contains package.json).
COPY . /app/piguild
WORKDIR /app/piguild
RUN npm ci && npm run build && npm prune --omit=dev

WORKDIR /app

VOLUME ["/workspace", "/app/config", "/root/.pi"]

ENV PIGUILD_CONFIG=/app/config/piguild.config.json

CMD ["sh", "-c", "rm -f /app/config/piguild.state.json.lock && pi -e /app/piguild/dist/index.js --no-session"]
